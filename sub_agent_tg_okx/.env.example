# Telegram Bot Token (from @BotFather)
TG_BOT_TOKEN=

# Telegram Chat ID (your chat ID or channel/group ID)
TG_CHAT_ID=

# OKX Instrument ID to monitor
INST_ID=ETH-USDT

# Check Interval in seconds (default 10s)
CHECK_INTERVAL=10

# Daily-equivalent alert threshold percentage (default 5.0 for 5%)
ALERT_THRESHOLD=5.0

# Cooldown between Telegram notifications in seconds (default 300s = 5m)
ALERT_COOLDOWN=300

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
